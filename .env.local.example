# ── Fireblocks sandbox credentials (SERVER-SIDE ONLY) ─────────────────────────
# These are NEVER exposed to the browser. They live only in the server runtime.
# Do NOT prefix any of these with NEXT_PUBLIC_.

# Your sandbox API key (UUID) from the Fireblocks Console (Settings → API Users).
FIREBLOCKS_API_KEY=your-sandbox-api-key

# Your RSA private key (the contents of fireblocks_secret.key).
# Two ways to provide it:
#   (A) Paste the whole PEM here with literal \n between lines (one line), OR
#   (B) leave this blank and put a fireblocks_secret.key file at the project root
#       (it's gitignored), the app reads that file if this var is empty.
# Canonical name (aligned across the suite). FIREBLOCKS_SECRET_KEY is also accepted.
FIREBLOCKS_PRIVATE_KEY=

# Path used if no inline key is set. Default: ./fireblocks_secret.key
# Canonical name (aligned across the suite). FIREBLOCKS_SECRET_PATH is also accepted.
FIREBLOCKS_SECRET_KEY_PATH=./fireblocks_secret.key

# Environment: "sandbox" | "us" | "eu". Keep sandbox for the demo.
FIREBLOCKS_ENV=sandbox

# Default asset for the transfer form (your sandbox uses Polygon Amoy).
NEXT_PUBLIC_DEFAULT_ASSET=AMOY_POLYGON_TEST

# ── Public-access gate (set these on Vercel so the live URL isn't open) ───────
# When both are set, the whole app requires this username/password (Basic Auth).
# Leave them unset locally to skip the prompt during development.
APP_ACCESS_USER=demo
APP_ACCESS_PASSWORD=change-me-before-sharing
